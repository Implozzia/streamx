# Database
# Railway автоматически задаёт DATABASE_URL при подключении PostgreSQL-сервиса
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/streamx

# JWT
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# App
APP_ENV=development
DEBUG=false

# CORS (comma-separated)
# Для разработки можно поставить: ALLOWED_ORIGINS=*
# Для прода: только нужные домены
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,http://localhost:8000,https://streamx.team

# Admin seed user
ADMIN_EMAIL=admin@streamx.team
ADMIN_PASSWORD=changeme123
ADMIN_FULL_NAME=Administrator

# Railway пробрасывает PORT автоматически — не добавляй его вручную в переменные Railway
# PORT=8000
